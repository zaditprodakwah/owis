{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/zaditprodakwah/owis/main/docs/20-SCHEMA/context.schema.json",
  "title": "Workspace Context Intelligence",
  "description": "Provider-Neutral Context Representation for LLMs",
  "type": "object",
  "required": ["contextVersion", "generatedAt", "sources"],
  "properties": {
    "contextVersion": {
      "type": "string",
      "enum": ["0.2.0"]
    },
    "generatedAt": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "properties": {
        "workspace": { "type": "string" },
        "wir": { "type": "string" },
        "graph": { "type": "string" },
        "lint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "workspace": {
      "type": "object",
      "description": "Base workspace metadata projection"
    },
    "architecture": {
      "type": "object",
      "description": "High-level architectural constraints and layers"
    },
    "graph": {
      "type": "object",
      "description": "Topological graph summary or structure projection"
    },
    "constraints": {
      "type": "object",
      "description": "System or domain constraints derived from WIR"
    },
    "quality": {
      "type": "object",
      "description": "Quality gates from linting reports"
    },
    "metadata": {
      "type": "object",
      "description": "Additional unstructured metadata projection"
    },
    "_truncated": {
      "type": "boolean",
      "description": "Indicates if the context was truncated to satisfy budget enforcement rules"
    }
  },
  "additionalProperties": false
}
